# Host ports. If TRAEFIK_HTTP_PORT changes, set PUBLIC_PORT to the same value.
PREVIEW_DEPLOYMENT_VERSION=latest
TRAEFIK_HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8082
ORCHESTRATOR_PORT=8081
PUBLIC_PORT=80

# Every preview is routed as <deployment-id>.<PREVIEW_DOMAIN>.
PREVIEW_DOMAIN=localhost
API_HOST=api.localhost
PUBLIC_SCHEME=http

# Optional bearer token for the orchestrator API. Leave blank to disable auth.
API_TOKEN=

# Optional host path mounted read-only at /run/secrets/codex-auth.json only when
# a deployment manifest explicitly sets "codex_auth": true. The generated
# entrypoint copies it privately into the container's writable CODEX_HOME.
CODEX_AUTH_PATH=

# Absolute host directory mounted at the identical path in the orchestrator.
# The stack installer fills an empty value with INSTALL_DIR/payloads.
PREVIEW_PAYLOAD_DIR=

# Comma-separated logical-key=local-image mappings. Images must already exist
# under the preview-runtime/ namespace on the preview Docker host.
PREVIEW_RUNTIMES=

MAX_UPLOAD_MB=128
MAX_BINARY_MB=256
MAX_DEPLOYMENTS=20
BUILD_CONCURRENCY=2
DEPLOY_TIMEOUT=10m
STOP_TIMEOUT_SECONDS=10

PREVIEW_MEMORY_MB=256
PREVIEW_CPUS=0.5
PREVIEW_PIDS_LIMIT=128
PREVIEW_TMPFS_MB=64
RUNTIME_IMAGE=debian:bookworm-slim
